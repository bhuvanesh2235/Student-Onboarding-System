# ═══════════════════════════════════════════════════════════════════
#  Student Onboarding System – Environment Variables Template
#  -----------------------------------------------------------
#  Copy this file to .env and replace placeholder values with
#  your actual credentials.
#
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=tododb
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_PORT=5432

# ── Spring Boot Backend ─────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/tododb
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
BACKEND_PORT=8080

# ── Python Pipeline ─────────────────────────────────────────────────
BACKEND_URL=http://backend:8080/students/bulk
PIPELINE_BATCH_SIZE=30
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY=2.0
PIPELINE_TOTAL_STUDENTS=120
PIPELINE_INVALID_RATIO=0.15

# ── React Frontend ──────────────────────────────────────────────────
# Used when running the frontend locally (outside Docker).
# Inside Docker, nginx proxies /api → backend so this is not needed.
REACT_APP_API_BASE_URL=http://localhost:8080

# ── Frontend Port ───────────────────────────────────────────────────
FRONTEND_PORT=3000
