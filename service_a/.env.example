# ── API Target ──────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8080/students/bulk

# ── Pipeline Tuning ─────────────────────────────────────────────────
PIPELINE_BATCH_SIZE=30
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY=2.0
PIPELINE_TOTAL_STUDENTS=120
PIPELINE_INVALID_RATIO=0.15
